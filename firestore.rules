rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read their own profile, but can list to check email availability
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null; // Allows the .where('email', ...) query
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Notes: only the owner can read/write/delete
    match /notes/{noteId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Custom Commands: only the owner can read/write/delete
    match /custom_commands/{commandId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Library: only the owner can read/write/delete
    match /library/{docId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Assessments: only the owner can read/write/delete
    match /assessments/{docId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Analytics: only developers can read aggregated data
    match /analytics/{document=**} {
      allow read: if request.auth != null && request.auth.token.email in [
        'developer1@example.com', // Add your developer emails here
        'developer2@example.com'
      ];
      allow write: if false; // Only server-side writes allowed
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}