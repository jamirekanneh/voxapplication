# Copy to assets/project.env and fill in your keys (project.env is gitignored).
# Rebuild the app after editing (hot reload does not reload env).

# Chat: OpenRouter is tried first; Groq is used if OpenRouter fails.
OPENROUTER_API_KEY=sk-or-v1-...
GROQ_API_KEY=gsk_...

# Voice note transcription uses GROQ_API_KEY only (Whisper).

# Optional custom NLP backend for chat (if set, tried before OpenRouter/Groq):
# NLP_API_URL=
# NLP_API_KEY=

# Contact Us email (EmailJS — https://dashboard.emailjs.com)
# 1) Copy these keys to functions/.env as well (for Cloud Function email delivery).
# 2) EmailJS → Account → Security → enable "Allow EmailJS API for non-browser applications".
# 3) Deploy: firebase deploy --only functions
# Recommendations are saved to Firestore only (collection "recommendations").
# EMAILJS_SERVICE_ID=service_akm5fyg
# EMAILJS_TEMPLATE_ID=template_ujtn37d
# EMAILJS_PUBLIC_KEY=your_public_key
# EMAILJS_PRIVATE_KEY=your_private_key
# CONTACT_SUPPORT_EMAIL=jamiremkanneh@gmail.com
