{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Vox Application (Debug)",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "Vox Application (Release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "Vox Application (Web)",
            "request": "launch",
            "type": "dart",
            "args": ["-d", "chrome", "--web-port", "8080"]
        },
        {
            "name": "Launch Chrome against localhost",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}